# ──── Authentication ────
JWT_SECRET=replace_with_openssl_rand_hex_64
REFRESH_SECRET=replace_with_openssl_rand_hex_64
JWT_EXPIRY=15m
REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# ──── Admin Seed ────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_immediately

# ──── Storage Paths (inside Docker container) ────
EXT4_MOUNT_PATH=/app/storage/ext4_mount
NTFS_MOUNT_PATH=/app/storage/windows_mount

# ──── Server ────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ──── Database ────
DATABASE_URL=file:./mediacloud.db
