# ════════════════════════════════════════════════════════════════
# MediaCloud — Production Environment Variables
# ════════════════════════════════════════════════════════════════
# Copy to .env.production and fill in real values before deploy.
# NEVER commit this file with real secrets to version control.

# ──── Authentication ────
# MUST be unique, random, 64+ characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
REFRESH_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_EXPIRY=15m
REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# ──── Admin Seed ────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ──── Storage Paths (set by docker-compose, do not change) ────
EXT4_MOUNT_PATH=/app/storage/ext4_mount
NTFS_MOUNT_PATH=/app/storage/windows_mount

# ──── Server ────
NODE_ENV=production
PORT=3000
# Your Cloudflare Tunnel domain
CORS_ORIGIN=https://cloud.yourdomain.com

# ──── Database (set by docker-compose, do not change) ────
DATABASE_URL=file:/app/data/mediacloud.db
